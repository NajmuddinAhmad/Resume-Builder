# Build My Resume — Environment Configuration
# Copy this file to .env and fill in your values

# ── Server ──
PORT=5000
NODE_ENV=development

# ── Database ──
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=build_my_resume
DATABASE_URL=postgresql://postgres:your_password_here@localhost:5432/build_my_resume

# ── JWT Secrets ──
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_key_change_this_too
JWT_REFRESH_EXPIRES_IN=30d

# ── Email (Nodemailer) ──
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=Build My Resume <noreply@buildmyresume.app>

# ── Google Gemini AI ──
GEMINI_API_KEY=your_gemini_api_key_here

# ── Frontend URL (for CORS and email links) ──
FRONTEND_URL=http://localhost:5001

# ── File Upload ──
MAX_FILE_SIZE=5mb
UPLOAD_DIR=./uploads
